<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>PermissionHub</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body>

    <nav class="navbar navbar-dark bg-dark navbar-expand-lg">
        <div class="container-fluid">

            <a class="navbar-brand" asp-page="/Index">
                PermissionHub
            </a>

            <div class="navbar-nav">

                <a class="nav-link text-white" asp-page="/Index">Companies</a>
                <a class="nav-link text-white" asp-page="/Users/Index">Users</a>
                <a class="nav-link text-white" asp-page="/UserRoles/AssignRole">Assign Role</a>

            </div>

            <div class="ms-auto">
                <a class="btn btn-sm btn-outline-light" asp-page="/Account/Logout">
                    Logout
                </a>
            </div>

        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

</body>
</html>